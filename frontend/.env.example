# Base URL được Axios sử dụng trong trình duyệt.
# Dùng đường dẫn tương đối để frontend và backend cùng origin qua Vite/Nginx proxy.
VITE_API_BASE_URL=/api/v1

# Chỉ dùng khi chạy npm run dev. Không được đưa biến này vào mã nguồn client.
VITE_DEV_PROXY_TARGET=http://localhost:4010

VITE_APP_NAME=LexiGo
