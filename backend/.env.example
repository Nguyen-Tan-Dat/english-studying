PORT=3000
NODE_ENV=development

# Replace this value with a long, random secret before deployment.
JWT_SECRET=change-this-development-secret-before-production
JWT_ISSUER=english-learning-api
JWT_AUDIENCE=english-learning-client
JWT_EXPIRES_IN_SECONDS=604800

# Password hashing and password-reset configuration.
BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXPIRES_IN_MINUTES=15
PASSWORD_RESET_URL=http://localhost:5173/reset-password
# Development only. Set false in production so raw reset tokens are never returned by the API.
RETURN_PASSWORD_RESET_TOKEN=true

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/english_learning
DB_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Alternative configuration:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=english_learning
# DB_USER=postgres
# DB_PASSWORD=your_password
