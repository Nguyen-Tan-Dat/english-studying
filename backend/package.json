{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express and TypeScript backend with PostgreSQL using Kysely",
  "main": "dist/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec \"ts-node --files src/server.ts\"",
    "watch": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "db:check": "ts-node --files src/database/check-connection.ts",
    "typecheck": "tsc --noEmit",
    "db:seed:rbac": "ts-node --files src/database/seed-rbac.ts",
    "db:grant-super-admin": "ts-node --files src/database/grant-super-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.17",
    "pg": "^8.22.0"
  }
}
