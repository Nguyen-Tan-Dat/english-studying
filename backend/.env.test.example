NODE_ENV=test

# This database is automatically created and rebuilt by npm test.
# SAFETY: its name must end with _test.
TEST_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/english_learning_test
DB_SSL=false
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=1000
DB_CONNECTION_TIMEOUT_MS=5000

JWT_SECRET=automatic-test-secret-at-least-32-characters
JWT_ISSUER=english-learning-api-test
JWT_AUDIENCE=english-learning-client-test
JWT_EXPIRES_IN_SECONDS=3600

# Faster hashing is acceptable only in automated tests.
BCRYPT_SALT_ROUNDS=4
PASSWORD_RESET_TOKEN_EXPIRES_IN_MINUTES=15
PASSWORD_RESET_URL=http://localhost:5173/reset-password
RETURN_PASSWORD_RESET_TOKEN=true
